# Environment Variables for Quiz AI App

# Groq API Key (Recommended - Free tier: 14,400 requests/day)
# Get your API key from: https://console.groq.com
# Leave empty to use Gemini only
GROQ_API_KEY=

# Gemini API Key (Fallback - Free tier: 20 requests/day per model)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyANt9WI56zqzUfP3M0p2gsLMkUfbFbUeWw

# Node Environment (automatically set by hosting platform)
NODE_ENV=production
